VITE_BASE_URL=/

VITE_APP_TITLE=SkyrocAdmin

VITE_APP_DESC=SkyrocAdmin is a fresh and elegant admin template

# the prefix of the icon name
VITE_ICON_PREFIX=icon

# the prefix of the local svg icon component, must include VITE_ICON_PREFIX
# format {VITE_ICON_PREFIX}-{local icon name}
VITE_ICON_LOCAL_PREFIX=icon-local

# constant route & auth route mode: static ｜ dynamic
VITE_AUTH_ROUTE_MODE=static

# static auth route home path
VITE_ROUTE_HOME=/dashboard/overview

# default menu icon
VITE_MENU_ICON=mdi:menu

# whether to enable http proxy when is dev mode
VITE_HTTP_PROXY=Y

# vue-router mode: hash | history | memory
VITE_ROUTER_HISTORY_MODE=history

# Align with Shared.Constants.ResponseCode (Success=200). Keep 0000 for mock compatibility.
VITE_SERVICE_SUCCESS_CODE=200,0000

# Silent redirect logout (no dedicated codes in ResponseCode currently)
VITE_SERVICE_LOGOUT_CODES=

# Auth/token failures → Modal then logout: 401 Unauthorized, 402 AuthenticationFailed, 403 Forbidden
VITE_SERVICE_MODAL_LOGOUT_CODES=401,402,403

# Access token expired → silent refresh + retry (ResponseCode.TokenExpired = 4011)
VITE_SERVICE_EXPIRED_TOKEN_CODES=4011

# when the route mode is static, the defined super role
VITE_STATIC_SUPER_ROLE=R_SUPER

# sourcemap
VITE_SOURCE_MAP=N

# Used to differentiate storage across different domains
VITE_STORAGE_PREFIX=SR_

# used to control whether the program automatically detects updates
VITE_AUTOMATICALLY_DETECT_UPDATE=Y

# backend service base url, test environment
VITE_SERVICE_BASE_URL=https://mock.apifox.cn/m1/3109515-0-default

# other backend service base url, test environment
VITE_OTHER_SERVICE_BASE_URL= `{
  "demo": "http://localhost:9528"
}`

# show proxy url log in terminal
VITE_PROXY_LOG=Y
