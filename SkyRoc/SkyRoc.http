@SkyRoc_HostAddress = http://localhost:5293
@contentType = application/json
@username = admin
@password = CHANGE_ME
@accessToken = REPLACE_WITH_BEARER_TOKEN
@refreshToken = REPLACE_WITH_REFRESH_TOKEN

# 可按需替换为真实 ID
@userId = 00000000-0000-0000-0000-000000000001
@roleId = 00000000-0000-0000-0000-000000000001
@menuId = 00000000-0000-0000-0000-000000000001
@menuButtonId = 00000000-0000-0000-0000-000000000001
@departmentId = 00000000-0000-0000-0000-000000000001
@companyId = 00000000-0000-0000-0000-000000000001
@customerId = 00000000-0000-0000-0000-000000000001
@customerTagId = 00000000-0000-0000-0000-000000000001
@customerSubAccountId = 00000000-0000-0000-0000-000000000001
@goodsTypeId = 00000000-0000-0000-0000-000000000001
@goodsId = 00000000-0000-0000-0000-000000000001
@goodsUnitId = 00000000-0000-0000-0000-000000000001
@quotationId = 00000000-0000-0000-0000-000000000001
@quotationGoodsId = 00000000-0000-0000-0000-000000000001
@customerProtocolId = 00000000-0000-0000-0000-000000000001
@customerProtocolGoodsId = 00000000-0000-0000-0000-000000000001
@supplierId = 00000000-0000-0000-0000-000000000001
@purchaserId = 00000000-0000-0000-0000-000000000001
@purchaseRuleId = 00000000-0000-0000-0000-000000000001
@wareId = 00000000-0000-0000-0000-000000000001
@orderId = 00000000-0000-0000-0000-000000000001
@orderDetailId = 00000000-0000-0000-0000-000000000001
@purchasePlanId = 00000000-0000-0000-0000-000000000001
@purchasePlanId2 = 00000000-0000-0000-0000-000000000002
@purchasePlanDetailId = 00000000-0000-0000-0000-000000000001

### Health
GET {{SkyRoc_HostAddress}}/health
Accept: {{contentType}}

### Login
POST {{SkyRoc_HostAddress}}/api/Auth/login
Content-Type: {{contentType}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

### Refresh Token
POST {{SkyRoc_HostAddress}}/api/Auth/refresh-token
Content-Type: {{contentType}}

{
  "refreshToken": "{{refreshToken}}"
}

### Get User Info
GET {{SkyRoc_HostAddress}}/api/Auth/getUserInfo
Authorization: Bearer {{accessToken}}
Accept: {{contentType}}

### Profile - Get Current User
GET {{SkyRoc_HostAddress}}/api/system/user/profile
Authorization: Bearer {{accessToken}}
Accept: {{contentType}}

### Profile - Update Current User
PUT {{SkyRoc_HostAddress}}/api/system/user/profile
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "nickName": "SkyRoc Admin",
  "gender": 1,
  "phone": "13800000000",
  "email": "admin@example.com"
}

### Profile - Change Current User Password
PUT {{SkyRoc_HostAddress}}/api/system/user/profile/updatePwd
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "oldPassword": "{{password}}",
  "newPassword": "NewPassword123!"
}

### Get Routes
GET {{SkyRoc_HostAddress}}/api/Auth/getRoutes
Authorization: Bearer {{accessToken}}
Accept: {{contentType}}

### Logout
POST {{SkyRoc_HostAddress}}/api/Auth/logout
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "refreshToken": "{{refreshToken}}"
}

### Users - List
