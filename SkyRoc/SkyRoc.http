@SkyRoc_HostAddress = http://localhost:5293
@contentType = application/json
@username = admin
@password = CHANGE_ME
@accessToken = REPLACE_WITH_BEARER_TOKEN
@refreshToken = REPLACE_WITH_REFRESH_TOKEN

# 可按需替换为真实 ID
@userId = 00000000-0000-0000-0000-000000000001
@roleId = 00000000-0000-0000-0000-000000000001
@menuId = 00000000-0000-0000-0000-000000000001
@menuButtonId = 00000000-0000-0000-0000-000000000001
@departmentId = 00000000-0000-0000-0000-000000000001
@companyId = 00000000-0000-0000-0000-000000000001
@customerId = 00000000-0000-0000-0000-000000000001
@customerTagId = 00000000-0000-0000-0000-000000000001
@customerSubAccountId = 00000000-0000-0000-0000-000000000001

### Health
GET {{SkyRoc_HostAddress}}/health
Accept: {{contentType}}

### Login
POST {{SkyRoc_HostAddress}}/api/Auth/login
Content-Type: {{contentType}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

### Refresh Token
POST {{SkyRoc_HostAddress}}/api/Auth/refresh-token
Content-Type: {{contentType}}

{
  "refreshToken": "{{refreshToken}}"
}

### Get User Info
GET {{SkyRoc_HostAddress}}/api/Auth/getUserInfo
Authorization: Bearer {{accessToken}}
Accept: {{contentType}}

### Profile - Get Current User
GET {{SkyRoc_HostAddress}}/api/system/user/profile
Authorization: Bearer {{accessToken}}
Accept: {{contentType}}

### Profile - Update Current User
PUT {{SkyRoc_HostAddress}}/api/system/user/profile
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "nickName": "SkyRoc Admin",
  "gender": 1,
  "phone": "13800000000",
  "email": "admin@example.com"
}

### Profile - Change Current User Password
PUT {{SkyRoc_HostAddress}}/api/system/user/profile/updatePwd
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "oldPassword": "{{password}}",
  "newPassword": "NewPassword123!"
}

### Get Routes
GET {{SkyRoc_HostAddress}}/api/Auth/getRoutes
Authorization: Bearer {{accessToken}}
Accept: {{contentType}}

### Logout
POST {{SkyRoc_HostAddress}}/api/Auth/logout
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "refreshToken": "{{refreshToken}}"
}

### Users - List
GET {{SkyRoc_HostAddress}}/api/Users/list?current=1&size=10
Authorization: Bearer {{accessToken}}
Accept: {{contentType}}

### Users - Get All
GET {{SkyRoc_HostAddress}}/api/Users
Authorization: Bearer {{accessToken}}
Accept: {{contentType}}

### Users - Get By Id
GET {{SkyRoc_HostAddress}}/api/Users/{{userId}}
Authorization: Bearer {{accessToken}}
Accept: {{contentType}}

### Users - Create
POST {{SkyRoc_HostAddress}}/api/Users
Content-Type: {{contentType}}

{
  "username": "codex_user_01",
  "gender": 1,
  "nickName": "Codex User",
  "phone": "13800000001",
  "email": "codex_user_01@example.com",
  "password": "ChangeMe123!",
  "status": 1
}

### Users - Update
PUT {{SkyRoc_HostAddress}}/api/Users
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "id": "{{userId}}",
  "username": "codex_user_01",
  "gender": 1,
  "nickName": "Codex User Updated",
  "phone": "13800000001",
  "email": "codex_user_01@example.com",
  "status": 1,
  "roleId": "{{roleId}}"
}

### Users - Assign Roles
POST {{SkyRoc_HostAddress}}/api/Users/assignRoles
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "userId": "{{userId}}",
  "roleIds": [
    "{{roleId}}"
  ]
}

### Users - Unassign Roles
DELETE {{SkyRoc_HostAddress}}/api/Users/unassignRoles
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "userId": "{{userId}}",
  "roleIds": [
    "{{roleId}}"
  ]
}

### Users - Delete
DELETE {{SkyRoc_HostAddress}}/api/Users/{{userId}}
Authorization: Bearer {{accessToken}}
Accept: {{contentType}}

### Roles - List
GET {{SkyRoc_HostAddress}}/api/Roles/list?current=1&size=10
