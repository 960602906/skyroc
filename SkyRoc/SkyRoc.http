Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "name": "北京示例学校后勤服务有限公司",
  "code": "CUST_SCHOOL_001",
  "companyId": "{{companyId}}",
  "contactName": "王老师",
  "contactPhone": "010-88886666",
  "address": "北京市海淀区知春路1号",
  "tagIds": [
    "{{customerTagId}}"
  ],
  "remark": "学校客户，创建时自动补全天眼查工商信息",
  "status": 1
}

### Customers - Update School Customer
