  "username": "codex_user_01",
  "gender": 1,
  "nickName": "Codex User",
  "phone": "13800000001",
  "email": "codex_user_01@example.com",
  "password": "ChangeMe123!",
  "status": 1
}

### Users - Update
PUT {{SkyRoc_HostAddress}}/api/Users
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

