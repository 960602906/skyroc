@goodsUnitId = 00000000-0000-0000-0000-000000000001
@quotationId = 00000000-0000-0000-0000-000000000001
@quotationGoodsId = 00000000-0000-0000-0000-000000000001
@customerProtocolId = 00000000-0000-0000-0000-000000000001
@customerProtocolGoodsId = 00000000-0000-0000-0000-000000000001
@supplierId = 00000000-0000-0000-0000-000000000001
@purchaserId = 00000000-0000-0000-0000-000000000001
@purchaseRuleId = 00000000-0000-0000-0000-000000000001
@wareId = 00000000-0000-0000-0000-000000000001
@orderId = 00000000-0000-0000-0000-000000000001
@orderDetailId = 00000000-0000-0000-0000-000000000001
@purchasePlanId = 00000000-0000-0000-0000-000000000001
@purchasePlanId2 = 00000000-0000-0000-0000-000000000002
@purchasePlanDetailId = 00000000-0000-0000-0000-000000000001
@purchaseOrderId = 00000000-0000-0000-0000-000000000001
@purchaseOrderDetailId = 00000000-0000-0000-0000-000000000001
@stockInPurchaseId = 00000000-0000-0000-0000-000000000001
@stockInOtherId = 00000000-0000-0000-0000-000000000001
@stockInSalesReturnId = 00000000-0000-0000-0000-000000000001
@stockBatchId = 00000000-0000-0000-0000-000000000001
@stockOutSaleId = 00000000-0000-0000-0000-000000000001
@stockOutPurchaseReturnId = 00000000-0000-0000-0000-000000000001
@stockOutOtherId = 00000000-0000-0000-0000-000000000001
@stockOutSaleDeleteDraftId = 00000000-0000-0000-0000-000000000001
@stockOutPurchaseReturnDeleteDraftId = 00000000-0000-0000-0000-000000000001
@stockOutOtherDeleteDraftId = 00000000-0000-0000-0000-000000000001
@stocktakingId = 00000000-0000-0000-0000-000000000001
